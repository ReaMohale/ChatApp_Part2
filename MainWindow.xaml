<Window x:Class="ChatApp_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡 SecureShield Awareness System"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F0B">

    <Window.Resources>

        <!-- ══ AGENT BUBBLE (right-aligned, purple) ══ -->
        <Style x:Key="AgentBubble" TargetType="Border">
            <Setter Property="Background" Value="#5A189A"/>
            <Setter Property="CornerRadius" Value="15,15,4,15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="100,5,15,5"/>
        </Style>

        <!-- ══ SHIELD BUBBLE (left-aligned, dark green) ══ -->
        <Style x:Key="ShieldBubble" TargetType="Border">
            <Setter Property="Background" Value="#132613"/>
            <Setter Property="CornerRadius" Value="4,15,15,15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="15,5,100,5"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ══ GREEN ACTION BUTTON ══ -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#1B4D1B"/>
            <Setter Property="Foreground" Value="#4ADE80"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="85"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2D6A2D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1B4D1B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ RED DANGER BUTTON ══ -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#8B2020"/>
            <Setter Property="Width" Value="85"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B2020"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ DRILL ANSWER BUTTON ══ -->
        <Style x:Key="DrillButton" TargetType="Button">
            <Setter Property="Background" Value="#0D1A0D"/>
            <Setter Property="Foreground" Value="#86EFAC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#132613"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#4ADE80"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ SLIM SCROLLBAR ══ -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#2D6A2D" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="*"/>
            <!-- chat -->
            <RowDefinition Height="Auto"/>
            <!-- drill panel -->
            <RowDefinition Height="Auto"/>
            <!-- input bar -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#0D1A0D"
                BorderBrush="#2D6A2D"
                BorderThickness="0,0,0,1">
            <StackPanel Margin="20,15">
                <!-- ASCII art — green tint -->
                <TextBlock FontFamily="Consolas"
                           FontSize="9"
                           Foreground="#4ADE80"
                           TextAlignment="Center"
                           FontWeight="Bold"
                           Text="╔════════════════════════════════════════════════════════════════════════════════╗&#x0a;║   ___  ____  ____  _  _  ____  ____  ___  _  _  ____  ____  __    ____      ║&#x0a;║  / __)( ___)/ ___)( )( )(  _ \( ___)/ __)( )( )(_  _)( ___)(  )  (  _ \     ║&#x0a;║  \__ \ )__)( (__  )()(  )   / )__)  \__ \ )__(  )(   )__)  )(__   )(_) )     ║&#x0a;║  (___/(____)\___)(____)(__)\_)(____)(___/(____)(__) (__)(__)(____)(____)     ║&#x0a;║                        &gt;&gt; Protecting You in the Digital Age &lt;&lt;              ║&#x0a;╚════════════════════════════════════════════════════════════════════════════════╝"/>

                <TextBlock Foreground="#6B7280"
                           FontSize="12"
                           TextAlignment="Center"
                           Margin="0,8,0,0">
                    <Run Text="SecureShield Awareness System" Foreground="#4ADE80" FontWeight="Bold"/>
                    <Run Text=" • "/>
                    <Run Text="Protecting You in the Digital Age"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ══ CHAT AREA ════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="#0B0F0B">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
            </ScrollViewer.Resources>
            <StackPanel x:Name="ChatPanel" Margin="15"/>
        </ScrollViewer>

        <!-- ══ DRILL PANEL (visible only during an active drill) ════════════ -->
        <Border x:Name="DrillPanelBorder"
                Grid.Row="2"
                Background="#0D1A0D"
                BorderBrush="#5A189A"
                BorderThickness="0,1,0,0"
                Padding="20,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="DrillQuestionText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#86EFAC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <StackPanel x:Name="DrillOptionsPanel"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock x:Name="DrillProgressText"
                               FontSize="11"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="DrillScoreText"
                               FontSize="11"
                               Foreground="#4ADE80"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ INPUT BAR ════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#0D1A0D"
                Padding="15"
                BorderBrush="#2D6A2D"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox"
                         Grid.Column="0"
                         Height="40"
                         FontSize="14"
                         Foreground="#86EFAC"
                         Background="#0B0F0B"
                         BorderBrush="#2D6A2D"
                         BorderThickness="1"
                         Padding="12,8"
                         CaretBrush="#4ADE80"
                         VerticalContentAlignment="Center"
                         TextWrapping="Wrap"
                         KeyDown="InputTextBox_KeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Style="{StaticResource ActionButton}"
                        Content="📤 Send"
                        Click="SendButton_Click"
                        Margin="10,0,0,0"/>

                <Button x:Name="ClearButton"
                        Grid.Column="2"
                        Style="{StaticResource DangerButton}"
                        Content="🗑️ Clear"
                        Click="ClearButton_Click"
                        Margin="5,0,0,0"/>
            </Grid>
        </Border>

    </Grid>
</Window>